# Generated by ansible
[mysqld]
server_id={{ node_id }}
bind_address=0.0.0.0
# gr_bind_ip comes from inventory (set per-host).
# For Lima local setups, this is the Lima foo-network IP (192.168.42.x).
# For GCP, leave it unset and it falls back to ansible_default_ipv4.address.
{% set bind_ip = gr_bind_ip | default(ansible_default_ipv4.address) %}
report_host={{ bind_ip }}
datadir=/var/lib/mysql
socket=/var/lib/mysql/mysql.sock
log-error=/var/log/mysql/mysqld.log
pid-file=/run/mysqld/mysqld.pid

# Binary logging
binlog_format=ROW
log_bin=binlog
log_bin_index=/var/lib/mysql/binlog.index
relay_log=mysql-relay-bin
relay_log_index=mysql-relay-bin.index
max_binlog_size=20M

# GTID
gtid_mode=ON
enforce_gtid_consistency=ON

# Group Replication
{% set seed_ips = [] %}
{% for h in groups['databases'] %}
{%   set _ = seed_ips.append(hostvars[h].gr_bind_ip | default(hostvars[h].ansible_default_ipv4.address)) %}
{% endfor %}
loose-group_replication_group_name={{ mysql_uuid }}
loose-group_replication_local_address={{ bind_ip }}:33061
loose-group_replication_group_seeds={{ seed_ips | map('regex_replace', '$', ':33061') | join(',') }}
loose-group_replication_ip_allowlist={{ seed_ips | join(',') }}
loose-group_replication_bootstrap_group=OFF
loose-group_replication_start_on_boot=OFF
loose-group_replication_ssl_mode=DISABLED
loose-group_replication_recovery_get_public_key=ON
disabled_storage_engines=MyISAM,BLACKHOLE,FEDERATED,ARCHIVE,MEMORY
